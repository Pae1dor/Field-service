<odoo noupdate="1">
    <!-- Location stages -->
    <record id="location_stage_1" model="fsm.stage">
        <field name="name">Active</field>
        <field name="sequence">1</field>
        <field name="stage_type">location</field>
        <field name="is_default" eval="True"/>
        <field name="custom_color">#27AE60</field>
    </record>

    <record id="location_stage_2" model="fsm.stage">
        <field name="name">On Hold</field>
        <field name="sequence">2</field>
        <field name="stage_type">location</field>
        <field name="custom_color">#F39C12</field>
    </record>

    <record id="location_stage_3" model="fsm.stage">
        <field name="name">Inactive</field>
        <field name="sequence">99</field>
        <field name="stage_type">location</field>
        <field name="is_closed" eval="True"/>
        <field name="fold" eval="True"/>
        <field name="custom_color">#7F8C8D</field>
    </record>

    <!-- Test location with territory hierarchy -->
    <record id="test_location" model="fsm.location">
        <field name="name">Test Location</field>
        <field name="phone">+66123456789</field>
        <field name="email">tloc@email.com</field>
        <field name="partner_id" ref="test_loc_partner"/>
        <field name="owner_id" ref="test_loc_partner"/>
        <field name="territory_id" ref="base_territory.test_territory"/>
        <field name="branch_id" ref="base_territory.test_branch"/>
        <field name="district_id" ref="base_territory.test_district"/>
        <field name="region_id" ref="base_territory.test_region"/>
        <field name="direction">Near the old inventory</field>
        <field name="street">14 Tower A, Main Street</field>
        <field name="street2">Bangkok, Thailand</field>
    </record>

    <!-- Generic locations -->
    <record id="location_1" model="fsm.location">
        <field name="name">Location 1</field>
        <field name="partner_id" ref="location_partner_1"/>
        <field name="owner_id" ref="location_partner_1"/>
    </record>

    <record id="location_2" model="fsm.location">
        <field name="name">Location 2</field>
        <field name="partner_id" ref="location_partner_2"/>
        <field name="owner_id" ref="location_partner_2"/>
    </record>

    <record id="location_3" model="fsm.location">
        <field name="name">Location 3</field>
        <field name="partner_id" ref="location_partner_3"/>
        <field name="owner_id" ref="location_partner_3"/>
    </record>
</odoo>