    <!-- === Per-group access rules === -->
    <record id="fsm_order_own_rule" model="ir.rule">
        <field name="name">FSM Orders: Own only</field>
        <field name="model_id" ref="model_fsm_order"/>
        <field name="domain_force">['|', ('person_id.user_ids', 'in', user.id), ('person_id', '=', False)]</field>
        <field name="groups" eval="[Command.link(ref('fieldservice.group_fsm_user_own'))]"/>
    </record>

    <record id="fsm_order_user_rule" model="ir.rule">
        <field name="name">FSM Orders: All</field>
        <field name="model_id" ref="model_fsm_order"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[Command.link(ref('fieldservice.group_fsm_user'))]"/>
    </record>
</odoo>