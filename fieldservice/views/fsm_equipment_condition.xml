<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fsm_equipment_condition_tree" model="ir.ui.view">
        <field name="name">fsm.equipment.condition.tree</field>
        <field name="model">fsm.equipment.condition</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="view_fsm_equipment_condition_form" model="ir.ui.view">
        <field name="name">fsm.equipment.condition.form</field>
        <field name="model">fsm.equipment.condition</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_fsm_equipment_condition" model="ir.actions.act_window">
        <field name="name">Equipment Conditions</field>
        <field name="res_model">fsm.equipment.condition</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>