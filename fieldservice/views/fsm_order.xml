<odoo>
    <!-- Operations -->
    <record id="fsm_order_form" model="ir.ui.view">
        <field name="name">fsm.order.form</field>
        <field name="model">fsm.order</field>
        <field name="arch" type="xml">
            <form string="Order">
                <header>
                    <!-- Flow buttons -->
                    <button name="action_assign_technician" string="Assign Technician"
                            type="object" class="btn-primary"
                            groups="fieldservice.group_fsm_dispatcher"
                            invisible="stage_id in [%(fieldservice.fsm_stage_completed)d, %(fieldservice.fsm_stage_cancelled)d] or sms_assigned_sent == True"/>
                    <button name="action_tech_depart" string="Technician Departed"
                            type="object" class="btn-secondary"
                            groups="fieldservice.group_fsm_user_own"
                            invisible="sms_assigned_sent == False or sms_depart_sent == True or stage_id in [%(fieldservice.fsm_stage_completed)d, %(fieldservice.fsm_stage_cancelled)d]"/>
                    <button name="action_customer_approve" string="Customer Approve"
                            type="object" class="btn-warning"
                            groups="fieldservice.group_fsm_dispatcher"
                            invisible="not customer_approval_required or customer_approved or stage_id in [%(fieldservice.fsm_stage_completed)d, %(fieldservice.fsm_stage_cancelled)d]"/>
                    <button
                        id="action_complete"
                        name="action_complete"
                        string="Complete Job"
                        class="oe_highlight"
                        type="object"
                        groups="fieldservice.group_fsm_user_own"
                        invisible="stage_id in [%(fieldservice.fsm_stage_completed)d, %(fieldservice.fsm_stage_cancelled)d]"
                    />
                    <field name="is_button" invisible="1" />
                    <button
                        id="action_cancel"
                        name="action_cancel"
                        string="Cancel Order"
                        type="object"
                        groups="fieldservice.group_fsm_dispatcher"
                        invisible="stage_id in [%(fieldservice.fsm_stage_completed)d, %(fieldservice.fsm_stage_cancelled)d]"
                    />
                    <!-- Hidden SMS state fields -->
                    <field name="sms_assigned_sent" invisible="1"/>
                    <field name="sms_depart_sent" invisible="1"/>
                    <field
                        name="stage_id"
                        widget="statusbar"
                        options="{'fold_field': 'fold'}"
                        domain="[('stage_type', '=', 'order'),
                                    '|', ('team_ids', 'in', team_id), ('team_ids', '=', False)]"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_check_stock" type="object"
                                class="oe_stat_button" icon="fa-cubes"
                                groups="fieldservice.group_fsm_dispatcher"
                                invisible="stage_id in [%(fieldservice.fsm_stage_completed)d, %(fieldservice.fsm_stage_cancelled)d]">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Check Stock</span>
                            </div>
                        </button>
                        <button name="action_view_pm_schedule" type="object"
                                class="oe_stat_button" icon="fa-calendar-check-o"
                                invisible="service_type_code != 'pm' or not pm_schedule_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">PM Schedule</span>
                            </div>
                        </button>
                        <div class="oe_stat_button" icon="fa-flag"
                             invisible="closing_gate_ok == False">
                            <field name="closing_gate_ok" invisible="1"/>
                            <div class="o_stat_info">
                                <span class="o_stat_text text-success">Closing Gate Passed</span>
                            </div>
                        </div>
                        <div class="oe_stat_button" icon="fa-flag"
                             invisible="closing_gate_ok == True">
                            <div class="o_stat_info">
                                <span class="o_stat_text text-warning">Closing Gate Pending</span>
                            </div>
                        </div>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="service_type_id"/>
                            <field name="service_type_code" invisible="1"/>
                            <field name="type" />
                            <field
                                name="template_id"
                                groups="fieldservice.group_fsm_template"
                            />
                            <field name="priority" widget="priority" />
                            <field
                                name="tag_ids"
                                widget="many2many_tags"
                                options="{'color_field': 'color', 'no_create_edit': True}"
                            />
                        </group>
                        <group>
                            <field name="location_id" />
                            <label for="street" string="Address" />
                            <div class="o_address_format">
                                <field name="street" class="o_address_street" />
                                <field name="street2" class="o_address_street" />
                                <field name="city" class="o_address_city" />
                                <field name="state_name" class="o_address_state" />
                                <field name="zip" class="o_address_zip" />
                                <field name="country_name" class="o_address_country" />
                            </div>
                            <field name="territory_id" invisible='1' />
                            <field name="branch_id" invisible='1' />
                            <field name="district_id" invisible='1' />
                            <field name="region_id" invisible='1' />
                            <field
                                name="team_id"
                            />
                            <field name="person_id" />
                            <field name="internal_type" invisible="1" />
                            <field name="sms_closed_sent" invisible="1"/>
                            <field
                                name="equipment_id"
                                invisible="internal_type not in ['repair', 'maintenance']"
                                groups="fieldservice.group_fsm_equipment"
                                options="{'no_create': True}"
                                domain="[('current_location_id','=',location_id)]"
                            />
                            <field
                                name="company_id"
                                options="{'no_create': True}"
                                groups="base.group_multi_company"
                            />
                        </group>
                    </group>
                    <group string="Description" name="description_grp">
                        <field name="description" nolabel="1" />
                    </group>
                    <group string="Resolution" name="resolution_grp">
                        <field name="resolution" nolabel="1" />
                    </group>
                    <notebook>
                        <page string="Planning" name="planning_page">
                            <group>
                                <group string="Requirements" name="requirements_grp">
                                    <field
                                        name="category_ids"
                                        widget="many2many_tags"
                                        options="{'color_field': 'color'}"
                                    />
                                    <field name="request_early" />
                                    <field name="request_late" />
                                </group>
                                <group id="schedule" string="Schedule Details">
                                    <field name="scheduled_date_start" />
                                    <field name="scheduled_duration" />
                                    <field name="scheduled_date_end" readonly="1" />
                                </group>
                            </group>
                            <group string="Request Workers" name="request_workers">
                                <field
                                    name="person_ids"
                                    widget="many2many"
                                    nolabel="1"
                                    context="{'search_default_location_ids': location_id}"
                                >
                                    <tree>
                                        <field name="name" />
                                        <field
                                            name="category_ids"
                                            widget="many2many_tags"
                                            options="{'color_field': 'color'}"
                                        />
                                        <field name="phone" />
                                        <field name="email" />
                                    </tree>
                                </field>
                            </group>
                        </page>
                        <page string="Instructions" name="instructions_page">
                            <group string="Instructions" name="instructions_grp">
                                <field name="todo" nolabel="1" />
                            </group>
                            <group
                                string="Location Directions"
                                name="location_directions_grp"
                            >
                                <field
                                    name="location_directions"
                                    nolabel="1"
                                    widget="html"
                                />
                            </group>
                        </page>
                        <page string="Execution" name="execution_page">
                            <group>
                                <group id="execution-left">
                                    <field name="date_start" />
                                    <field name="date_end" />
                                    <field name="duration" readonly="1" />
                                </group>
                                <group id="execution-right" />
                            </group>
                        </page>
                        <!-- PHE Check Sheet Tab -->
                        <page string="PHE Units (Check Sheet)" name="phe_units_page"
                              invisible="service_type_code != 'phe'">
                            <group>
                                <group>
                                    <field name="customer_approval_required"/>
                                    <field name="customer_approved"
                                           invisible="not customer_approval_required"/>
                                    <field name="all_phe_units_done" readonly="1"/>
                                </group>
                                <group>
                                    <field name="phe_unit_count" readonly="1"
                                           string="Total Units"/>
                                </group>
                            </group>
                            <field name="phe_unit_ids" context="{'default_order_id': id}"
                                   mode="tree"/>
                        </page>

                        <!-- PM Tab -->
                        <page string="PM Report" name="pm_page"
                              invisible="service_type_code != 'pm'">
                            <group>
                                <group>
                                    <field name="pm_schedule_id"/>
                                    <field name="equipment_condition_id"/>
                                </group>
                            </group>
                            <group string="PM Report / Equipment Condition">
                                <field name="pm_report" nolabel="1"
                                       placeholder="Record equipment condition, inspection items, replaced parts..."/>
                            </group>
                        </page>

                        <page
                            string="Equipments"
                            groups="fieldservice.group_fsm_equipment"
                            name="equipements_page"
                            invisible="internal_type in ['repair', 'maintenance']"
                        >
                            <field
                                name="equipment_ids"
                                required="internal_type not in ['repair', 'maintenance']"
                                options="{'no_create': True}"
                                domain="[('current_location_id','=',location_id)]"
                            >
                                <tree>
                                    <field name="name" />
                                    <field name="person_id" />
                                    <field name="location_id" />
                                    <field name="current_location_id" />
                                    <field name="stage_id" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="fsm_order_tree_view" model="ir.ui.view">
        <field name="name">fsm.order.tree</field>
        <field name="model">fsm.order</field>
        <field name="arch" type="xml">
            <tree name="orders" default_order="scheduled_date_start">
                <field name="scheduled_date_start" />
                <field name="scheduled_date_end" />
                <field name="name" />
                <field name="location_id" />
                <field name="person_id" />
                <field name="tag_ids" widget="many2many_tags" optional="show" />
                <field name="stage_id" string="Stage" />
                <field name="company_id" groups="base.group_multi_company" />
            </tree>
        </field>
    </record>
    <record id="action_fsm_operation_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">fsm.order</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create an Order.
            </p>
        </field>
    </record>
    <!-- Dashboard -->
    <record id="fsm_order_kanban_view" model="ir.ui.view">
        <field name="name">fsm.order.kanban</field>
        <field name="model">fsm.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column">
                <field
                    name="stage_id"
                    options='{"group_by_tooltip": {"description": "Description"}}'
                />
                <field name="name" />
                <field name="priority" />
                <field name="location_id" />
                <field name="person_id" />
                <field name="color" />
                <field name="tag_ids" />
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{kanban_color(record.color.value)} oe_kanban_global_click">
                            <div class="o_dropdown_kanban dropdown">
                                <a
                                    role="button"
                                    class="dropdown-toggle o-no-caret btn"
                                    data-bs-toggle="dropdown"
                                    href="#"
                                    aria-label="Dropdown menu"
                                    title="Dropdown menu"
                                >
                                    <span class="fa fa-ellipsis-v" />
                                </a>
                                <div class="dropdown-menu" role="menu">
                                    <a
                                        role="menuitem"
                                        type="delete"
                                        class="dropdown-item"
                                    >Delete</a>
                                    <div role="separator" class="dropdown-divider" />
                                    <ul class="oe_kanban_colorpicker" data-field="color" />
                                </div>
                            </div>
                            <div class="oe_kanban_content">
                                <div>
                                    <strong class="o_kanban_record_title">
                                        <field name="name" />
                                    </strong>
                                </div>
                                <div>
                                    <field
                                        name="tag_ids"
                                        widget="many2many_tags"
                                        options="{'color_field': 'color'}"
                                    />
                                </div>
                                <div>
                                    <field name="location_id" />
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field
                                            name="priority"
                                            widget="priority"
                                            groups="fieldservice.group_fsm_dispatcher"
                                        />
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="person_id" widget="many2one_avatar" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Search for fsm.order-->
    <record id="fsm_order_search_view" model="ir.ui.view">
        <field name="name">fsm.order.search</field>
        <field name="model">fsm.order</field>
        <field name="arch" type="xml">
            <search string="Orders">
                <filter
                    string="My Orders"
                    domain="[('person_id.partner_id.user_ids', '=', uid)]"
                    name="my_orders"
                />
                <separator />
                <field
                    name="name"
                    filter_domain="['|', ('name', 'ilike', self), ('name', '=like', str(self) + '%')]"
                    string="FSM Order Name"
                />
                <field name="location_id" />
                <field name="branch_id" />
                <field name="district_id" />
                <field name="region_id" />
                <field name="team_id" />
                <field name="person_id" />
                <field name="person_ids" />
                <separator />
                <filter
                    string="To Do"
                    domain="[('stage_id.is_closed', '=', False)]"
                    name="todo"
                />
                <filter
                    string="Unassigned"
                    domain="[('person_id', '=', False), ('stage_id.is_closed', '=', False)]"
                    name="unassigned"
                />
                <filter
                    string="Unscheduled"
                    domain="[('scheduled_date_start', '=', False), ('stage_id.is_closed', '=', False)]"
                    name="unscheduled"
                />
                <filter
                    string="Done"
                    domain="[('stage_id.is_closed', '=', True)]"
                    name="done"
                />
                <separator />
                <filter
                    string="Today Orders"
                    domain="[
                    ('scheduled_date_start', '&gt;=', (datetime.datetime.combine(datetime.date.today(), datetime.time(0,0,0)))),
                    ('scheduled_date_start', '&lt;', (datetime.datetime.combine(datetime.date.today(), datetime.time(23,59,59))))
                    ]"
                    name="order_today"
                />
                <filter
                    string="Future Orders"
                    domain="[('scheduled_date_start', '&gt;=', (datetime.datetime.combine(datetime.date.today(), datetime.time(0,0,0))))]"
                    name="order_upcoming_all"
                />
                <filter
                    string="Due Within 7 Days"
                    domain="[
                    ('scheduled_date_start', '&gt;=', (datetime.datetime.combine(datetime.date.today(), datetime.time(0,0,0)))),
                    ('scheduled_date_start', '&lt;=', (datetime.datetime.combine((datetime.date.today()+relativedelta(days=6)), datetime.time(23,59,59))))
                    ]"
                    name="order_upcoming_week"
                />
                <filter
                    string="Due Within 30 Days"
                    domain="[
                    ('scheduled_date_start', '&gt;=',(datetime.datetime.combine(datetime.date.today(), datetime.time(0,0,0)))),
                    ('scheduled_date_start', '&lt;=', (datetime.datetime.combine((datetime.date.today()+relativedelta(days=29)), datetime.time(23,59,59))))
                    ]"
                    name="order_upcoming_month"
                />
                <separator />
                <group expand="0" string="Group By">
                    <filter
                        name="territory_id"
                        string="Territory"
                        domain=""
                        context="{'group_by':'territory_id'}"
                    />
                    <filter
                        name="branch_id"
                        string="Branch"
                        domain=""
                        context="{'group_by':'branch_id'}"
                    />
                    <filter
                        name="district_id"
                        string="District"
                        domain=""
                        context="{'group_by':'district_id'}"
                    />
                    <filter
                        name="region_id"
                        string="Region"
                        domain=""
                        context="{'group_by':'region_id'}"
                    />
                    <filter
                        name="fsm_person_id"
                        domain=""
                        context="{'group_by':'person_id'}"
                    />
                </group>
            </search>
        </field>
    </record>
    <record id="fsm_order_calendar_view" model="ir.ui.view">
        <field name="name">Orders</field>
        <field name="model">fsm.order</field>
        <field name="type">calendar</field>
        <field name="arch" type="xml">
            <calendar
                string="FSM Orders"
                date_start="scheduled_date_start"
                date_delay="scheduled_duration"
                color="stage_id"
            >
                <field name="name" />
                <field name="stage_id" filters="1" />
                <field name="location_id" />
                <field name="phone" />
                <field
                    name="person_id"
                    write_model="fsm.person.calendar.filter"
                    write_field="fsm_person_id"
                    avatar_field="image_128"
                />
                <field name="team_id" filters="1" />
                <field name="person_phone" />
                <field name="city" />
                <field name="state_name" />
            </calendar>
        </field>
    </record>
    <record id="action_fsm_dash_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">fsm.order</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="search_view_id" ref="fsm_order_search_view" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create an Order.
            </p>
        </field>
    </record>
    <!-- Reporting -->
    <record id="fsm_order_graph_view" model="ir.ui.view">
        <field name="name">fsm.order.graph</field>
        <field name="model">fsm.order</field>
        <field name="arch" type="xml">
            <graph string="Service Orders" type="bar">
                <field name="stage_id" type="row" />
            </graph>
        </field>
    </record>
    <record id="fsm_order_pivot_view" model="ir.ui.view">
        <field name="name">fsm.order.pivot</field>
        <field name="model">fsm.order</field>
        <field name="arch" type="xml">
            <pivot string="Service Orders" display_quantity="true">
                <field name="stage_id" type="row" />
            </pivot>
        </field>
    </record>
    <record id="action_fsm_report_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">fsm.order</field>
        <field name="view_mode">graph,pivot</field>
        <field name="help" type="html">
            <p>
                Orders Reports.
            </p>
        </field>
    </record>
    <record id="action_report_fsm_order" model="ir.actions.report">
        <field name="name">Service Order</field>
        <field name="model">fsm.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">fieldservice.report_fsm_order</field>
        <field name="report_file">fieldservice.report_fsm_order</field>
        <field name="print_report_name">'Service Order - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_fsm_order" />
    </record>
</odoo>
