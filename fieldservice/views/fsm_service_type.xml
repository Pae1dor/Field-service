<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fsm_service_type_tree" model="ir.ui.view">
        <field name="name">fsm.service.type.tree</field>
        <field name="model">fsm.service.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="view_fsm_service_type_form" model="ir.ui.view">
        <field name="name">fsm.service.type.form</field>
        <field name="model">fsm.service.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_fsm_service_type" model="ir.actions.act_window">
        <field name="name">Service Types</field>
        <field name="res_model">fsm.service.type</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>