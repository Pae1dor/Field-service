<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fsm_pm_frequency_tree" model="ir.ui.view">
        <field name="name">fsm.pm.frequency.tree</field>
        <field name="model">fsm.pm.frequency</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="months"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="view_fsm_pm_frequency_form" model="ir.ui.view">
        <field name="name">fsm.pm.frequency.form</field>
        <field name="model">fsm.pm.frequency</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="months"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_fsm_pm_frequency" model="ir.actions.act_window">
        <field name="name">PM Frequencies</field>
        <field name="res_model">fsm.pm.frequency</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>